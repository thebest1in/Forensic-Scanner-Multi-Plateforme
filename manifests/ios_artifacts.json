        "triage": {
            "name": "Triage Mode",
            "description": "Device info + installed apps + basic backup analysis",
            "artifacts": [
                {
                    "id": "device_information",
                    "parser": "ios.device_info",
                    "function": "extract_device_summary",
                    "description": "Device model, OS version, serial number",
                    "source_type": "live",
                    "yara_scan": false,
                    "requires_backup": false
                },
                {
                    "id": "pairing_status",
                    "parser": "ios.acquisition",
                    "function": "pair_device",
                    "description": "Device pairing/trust status",
                    "source_type": "live",
                    "yara_scan": false,
                    "requires_backup": false
                },
                {
                    "id": "installed_applications",
                    "parser": "ios.applications",
                    "function": "parse_installed_apps",
                    "description": "All installed apps with bundle IDs",
                    "source_type": "backup",
                    "yara_scan": false,
                    "requires_backup": true
                },
                {
                    "id": "backup_manifest",
                    "parser": "ios.backup",
                    "function": "read_manifest_database",
                    "description": "Backup file manifest (Manifest.db)",
                    "source_type": "backup",
                    "yara_scan": false,
                    "requires_backup": true
                },
                {
                    "id": "backup_metadata",
                    "parser": "ios.backup",
                    "function": "parse_info_plist",
                    "description": "Info.plist and Status.plist metadata",
                    "source_type": "backup",
                    "yara_scan": false,
                    "requires_backup": true
                },
                {
                    "id": "configuration_profiles",
                    "parser": "ios.parsers.profiles",
                    "function": "parse_configuration_profiles",
                    "description": "MDM profiles and VPN configurations",
                    "source_type": "backup",
                    "yara_scan": false,
                    "requires_backup": true
                }
            ]
        },
